# OpenCode Coding Template — minimal environment
# Copy to .env and fill only the values you need.
# Do not commit real secrets.

# Model selectors used by opencode.json. These defaults use the bundled Makora
# provider example; replace them with any provider/model IDs available to you.
OPENCODE_MODEL=makora/glm-5.1-fp8
OPENCODE_SMALL_MODEL=makora/qwen3.6-27b-nvfp4
OPENCODE_PLAN_MODEL=makora/deepseek-v4-pro

# Provider auth is normally handled by OpenCode, for example:
#   opencode auth login makora
# If your chosen provider requires API-key environment variables, keep them in
# your local .env or a secret manager and document them in an optional env file.

# Optional project behavior toggles.
OPENCODE_EXPERIMENTAL_BASH_DEFAULT_TIMEOUT_MS=300000
OPENCODE_DISABLE_PROJECT_CONFIG=0
