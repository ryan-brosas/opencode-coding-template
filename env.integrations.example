# OpenCode Coding Template — optional integrations
# Copy selected values into .env only when you enable the matching MCP, plugin,
# command, or skill. Keep real credentials out of git.

# Context7 — library documentation lookup
# Used by the optional/custom context7 tool when configured for API-backed access.
CONTEXT7_API_KEY=your_context7_api_key_here

# Exa — web search / code context
EXA_API_KEY=your_exa_api_key_here

# Provider credentials — normally prefer `opencode auth login <provider>`.
# Add env vars only if your provider or wrapper explicitly reads them.
# Makora example models are referenced by root .env.example.
# MAKORA_API_KEY=your_makora_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Git hosting / org workflows — org-pack skills.
# GITHUB_TOKEN=your_github_token_here
# GITLAB_TOKEN=your_gitlab_token_here
# GH_TOKEN=your_github_cli_token_here

# Figma — UI/design workflows (.opencode/skill/figma/).
# FIGMA_API_KEY=your_figma_api_key_here
# FIGMA_ACCESS_TOKEN=your_figma_access_token_here

# Webclaw — brand/site extraction (.opencode/skill/webclaw/).
# WEBCLAW_API_KEY=your_webclaw_api_key_here

# Tilth — AST/code search MCP. Most local tilth usage needs no API key.
# TILTH_API_KEY=your_tilth_api_key_here

# Cloudflare / GCP / deployment workflows — cloud-pack skills.
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1

# Optional local MCP servers noted in opencode.json are disabled by default.
# Enable only after installing and reviewing the command they run.
# - tilth: npx -y tilth --mcp --edit
# - webclaw: webclaw-mcp
# - figma-mcp-go: npx -y @vkhanhqui/figma-mcp-go@latest
