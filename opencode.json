{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Primary development agent with full codebase access",
      "model": "{env:OPENCODE_MODEL}"
    },
    "compaction": {
      "description": "Session summarizer for context continuity across compactions",
      "model": "{env:OPENCODE_SMALL_MODEL}"
    },
    "explore": {
      "description": "Fast codebase search specialist",
      "model": "{env:OPENCODE_SMALL_MODEL}"
    },
    "general": {
      "description": "General-purpose subagent for fast, well-defined tasks; delegates complexity quickly",
      "model": "{env:OPENCODE_SMALL_MODEL}"
    },
    "plan": {
      "description": "Primary planning agent for architecture and multi-phase execution",
      "model": "{env:OPENCODE_PLAN_MODEL}"
    },
    "review": {
      "description": "Code review, debugging, and security audit specialist",
      "model": "{env:OPENCODE_SMALL_MODEL}"
    },
    "scout": {
      "description": "External research specialist for library docs and patterns",
      "model": "{env:OPENCODE_SMALL_MODEL}"
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "reserved": 16000
  },
  "formatter": {
    "biome": {
      "command": [
        "npx",
        "@biomejs/biome",
        "check",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc"
      ]
    },
    "cargo-fmt": {
      "command": [
        "cargo",
        "fmt",
        "--",
        "$FILE"
      ],
      "extensions": [
        ".rs"
      ]
    },
    "java-formatter": {
      "command": [
        "google-java-format",
        "--replace",
        "$FILE"
      ],
      "environment": {
        "JAVA_HOME": "{env:JAVA_HOME}"
      },
      "extensions": [
        ".java"
      ]
    },
    "laravel-pint": {
      "command": [
        "npx",
        "laravel-pint",
        "--preset",
        "psr12",
        "$FILE"
      ],
      "extensions": [
        ".php"
      ]
    },
    "oxfmt": {
      "command": [
        "npx",
        "oxfmt",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc",
        ".html",
        ".css",
        ".scss",
        ".sass",
        ".md",
        ".mdx",
        ".yaml",
        ".yml"
      ]
    }
  },
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/memory/project/user.md",
    ".opencode/memory/project/tech-stack.md",
    ".opencode/memory/project/project.md",
    ".opencode/context/git-context.md"
  ],
  "mcp": {
    "figma-mcp-go": {
      "command": [
        "npx",
        "-y",
        "@vkhanhqui/figma-mcp-go@latest"
      ],
      "enabled": false,
      "timeout": 120000,
      "type": "local"
    },
    "tilth": {
      "command": [
        "npx",
        "-y",
        "tilth",
        "--mcp",
        "--edit"
      ],
      "enabled": false,
      "environment": {
        "TILTH_THREADS": "8"
      },
      "timeout": 120000,
      "type": "local"
    },
    "webclaw": {
      "command": [
        "webclaw-mcp"
      ],
      "enabled": false,
      "timeout": 120000,
      "type": "local"
    }
  },
  "model": "{env:OPENCODE_MODEL}",
  "permission": {
    "bash": {
      "cat *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git status*": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "npm run build": "allow",
      "npm run lint": "allow",
      "npm run test": "allow",
      "npm run typecheck": "allow",
      "bunx *": "ask",
      "git checkout *": "ask",
      "git clean *": "ask",
      "git commit *": "ask",
      "git merge *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "npm *": "ask",
      "npx *": "ask",
      "pnpm dlx *": "ask",
      "npm publish *": "ask",
      "npm run db:push*": "ask",
      "npm run db:reset*": "deny",
      "rm*": "deny",
      "sudo*": "deny",
      "*": "ask"
    },
    "doom_loop": "ask",
    "edit": "allow",
    "external_directory": "ask",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env.example": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.key": "deny",
      "*.pem": "deny",
      "*credentials*": "deny",
      "*password*": "deny",
      "*secret*": "deny",
      "*token*": "deny"
    }
  },
  "plugin": [],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.2": {
          "variants": {
            "fast": {
              "disabled": true
            },
            "high": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.2-codex": {
          "variants": {
            "fast": {
              "disabled": true
            },
            "high": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "xhigh": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.3-codex": {
          "variants": {
            "fast": {
              "disabled": true
            },
            "high": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "xhigh": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.4": {
          "attachment": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "textVerbosity": "medium"
          },
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "variants": {
            "high": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto"
            }
          }
        }
      }
    },
    "makora": {
      "name": "Makora",
      "options": {
        "baseURL": "https://inference.makora.com/v1",
        "timeout": 600000
      },
      "models": {
        "deepseek-v4-flash": {
          "id": "deepseek-ai/DeepSeek-V4-Flash",
