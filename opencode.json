  "share": "manual",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "*.log",
      ".DS_Store"
    ]
  },
  "enabled_providers": [
    "openai",
    "makora"
  ]
}
