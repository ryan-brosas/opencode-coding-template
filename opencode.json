        }
    },
    "share": "manual",
    "small_model": "makora/qwen3.6-35b-a3b-nvfp4",
    "watcher": {
        "ignore": [
            "node_modules/**",
            ".git/**",
            "dist/**",
            "build/**",
            "*.log",
            ".DS_Store"
        ]
    },
    "enabled_providers": [
        "openai",
        "makora"
    ]
}
