{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "build": {
            "description": "Primary development agent with full codebase access",
            "model": "makora/deepseek-v4-flash"
        },
        "compaction": {
            "description": "Session summarizer for context continuity across compactions",
            "model": "makora/qwen3.6-35b-a3b-nvfp4"
        },
        "explore": {
            "description": "Fast read-only file and code search specialist for locating files, symbols, and usage patterns",
            "model": "makora/qwen3.6-35b-a3b-nvfp4"
        },
        "general": {
            "description": "General-purpose subagent for small, well-defined implementation tasks",
            "model": "makora/qwen3.6-35b-a3b-nvfp4"
        },
        "plan": {
            "description": "Planning agent for architecture, decomposition, and executable implementation plans",
            "model": "makora/deepseek-v4-pro"
        },
        "review": {
            "description": "Read-only code review and debugging specialist for correctness, security, and regressions",
            "model": "makora/qwen3.6-35b-a3b-nvfp4"
        },
        "scout": {
            "description": "External research specialist for library docs and patterns",
            "model": "makora/qwen3.6-35b-a3b-nvfp4"
        },
        "painter": {
            "description": "Image generation and editing specialist for mockups, icons, and visual assets",
            "model": "openai/gpt-5.4"
        },
        "vision": {
            "description": "Read-only frontend/UI review specialist for visual correctness, UX quality, accessibility, and implementation QA",
            "model": "openai/gpt-5.4"
        }
    },
    "autoupdate": true,
    "compaction": {
        "auto": true,
        "reserved": 16000
    },
    "formatter": {
        "cargo-fmt": {
            "command": [
                "cargo",
                "fmt",
                "--",
                "$FILE"
            ],
            "extensions": [
                ".rs"
            ]
        },
        "java-formatter": {
            "command": [
                "google-java-format",
                "--replace",
                "$FILE"
            ],
            "environment": {
                "JAVA_HOME": "{env:JAVA_HOME}"
            },
            "extensions": [
                ".java"
            ]
        },
        "oxfmt": {
            "command": [
                "npx",
                "oxfmt",
                "--write",
                "$FILE"
            ],
            "extensions": [
                ".js",
                ".jsx",
                ".ts",
                ".tsx",
                ".json",
                ".jsonc",
                ".html",
                ".css",
                ".scss",
                ".sass",
                ".md",
                ".mdx",
                ".yaml",
                ".yml"
            ]
        }
    },
    "instructions": [
        ".opencode/AGENTS.md",
        ".opencode/context/git-context.md"
    ],
    "mcp": {
        "figma-mcp-go": {
            "command": [
                "npx",
                "-y",
                "@vkhanhqui/figma-mcp-go@latest"
            ],
            "enabled": false,
            "timeout": 120000,
            "type": "local"
        },
        "tilth": {
            "command": [
                "npx",
                "-y",
                "tilth",
                "--mcp",
                "--edit"
            ],
            "enabled": false,
            "environment": {
                "TILTH_THREADS": "8"
            },
            "timeout": 120000,
            "type": "local"
        },
        "webclaw": {
            "command": [
                "webclaw-mcp"
            ],
            "enabled": false,
            "timeout": 120000,
            "type": "local"
        }
    },
    "model": "makora/glm-5.1-fp8",
    "permission": {
        "bash": {
            "cat *": "allow",
            "find *": "allow",
            "git branch *": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "git status*": "allow",
            "grep *": "allow",
            "ls *": "allow",
            "rg *": "allow",
            "npm run build": "allow",
            "npm run lint": "allow",
            "npm run test": "allow",
            "npm run typecheck": "allow",
            "bunx *": "ask",
            "git checkout *": "ask",
            "git clean *": "ask",
            "git commit *": "ask",
            "git merge *": "ask",
            "git push *": "ask",
            "git rebase *": "ask",
            "git reset *": "ask",
            "npm *": "ask",
            "npx *": "ask",
            "pnpm dlx *": "ask",
            "npm publish *": "ask",
            "npm run db:push*": "ask",
            "npm run db:reset*": "deny",
            "rm*": "deny",
            "sudo*": "deny",
            "*": "ask"
        },
        "doom_loop": "ask",
        "edit": "allow",
        "external_directory": "ask",
        "question": "allow",
        "read": {
            "*": "allow",
            "*.env.example": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.key": "deny",
            "*.pem": "deny",
            "*credentials*": "deny",
            "*password*": "deny",
            "*secret*": "deny",
            "*token*": "deny"
        }
    },
    "plugin": [],
    "provider": {
        "openai": {
            "models": {
                "gpt-5.2": {
                    "variants": {
                        "fast": {
                            "disabled": true
                        },
                        "high": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "high",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        },
                        "medium": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "medium",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        }
                    }
                },
                "gpt-5.2-codex": {
                    "variants": {
                        "fast": {
                            "disabled": true
                        },
                        "high": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "high",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        },
                        "medium": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "medium",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        },
                        "xhigh": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "xhigh",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        }
                    }
                },
                "gpt-5.3-codex": {
                    "variants": {
                        "fast": {
                            "disabled": true
                        },
                        "high": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "high",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        },
                        "medium": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "medium",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        },
                        "xhigh": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "xhigh",
                            "reasoningSummary": "auto",
                            "textVerbosity": "low"
                        }
                    }
                },
                "gpt-5.4": {
                    "attachment": true,
                    "limit": {
                        "context": 400000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "options": {
                        "reasoningEffort": "medium",
                        "reasoningSummary": "auto",
                        "textVerbosity": "medium"
                    },
                    "reasoning": true,
                    "temperature": true,
                    "tool_call": true,
                    "variants": {
                        "high": {
                            "include": [
                                "reasoning.encrypted_content"
                            ],
                            "reasoningEffort": "high",
                            "reasoningSummary": "auto"
                        },
                        "low": {
                            "reasoningEffort": "low",
                            "reasoningSummary": "auto"
                        },
                        "medium": {
                            "reasoningEffort": "medium",
                            "reasoningSummary": "auto"
                        }
                    }
                }
            }
        },
        "makora": {
            "name": "Makora",
            "options": {
                "baseURL": "https://inference.makora.com/v1",
                "timeout": 600000
            },
            "models": {
                "deepseek-v4-flash": {
                    "id": "deepseek-ai/DeepSeek-V4-Flash",
                    "name": "DeepSeek V4 Flash",
                    "attachment": false,
                    "reasoning": true,
                    "tool_call": true,
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 1048576,
                        "output": 1048576
                    }
                },
                "deepseek-v4-pro": {
