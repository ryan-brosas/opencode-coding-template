{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Primary development agent with full codebase access",
      "model": "makora/glm-5.1-fp8"
    },
    "compaction": {
      "description": "Session summarizer for context continuity across compactions",
      "model": "makora/qwen3.6-27b-nvfp4"
    },
    "explore": {
      "description": "Fast codebase search specialist",
      "model": "makora/qwen3.6-27b-nvfp4"
    },
    "general": {
      "description": "General-purpose subagent for fast, well-defined tasks; delegates complexity quickly",
      "model": "makora/qwen3.6-27b-nvfp4"
    },
    "painter": {
      "description": "Image generation and editing specialist using Gemini 3 Pro Image. Use for creating UI mockups, app icons, hero images, visual assets, and editing/redacting existing images",
      "model": "makora/qwen3.6-27b-nvfp4"
    },
    "plan": {
      "description": "Primary planning agent for architecture and multi-phase execution",
      "model": "makora/deepseek-v4-pro"
    },
    "review": {
      "description": "Code review, debugging, and security audit specialist",
      "model": "makora/qwen3.6-27b-nvfp4"
    },
    "scout": {
      "description": "External research specialist for library docs and patterns",
      "model": "makora/qwen3.6-27b-nvfp4"
    },
    "vision": {
      "description": "Visual content specialist for multimodal analysis and UI/UX guidance",
      "model": "makora/qwen3.6-27b-nvfp4"
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": false,
    "reserved": 16000
  },
  "formatter": {
    "biome": {
      "command": ["npx", "@biomejs/biome", "check", "--write", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc"]
    },
    "cargo-fmt": {
      "command": ["cargo", "fmt", "--", "$FILE"],
      "extensions": [".rs"]
    },
    "java-formatter": {
      "command": ["google-java-format", "--replace", "$FILE"],
      "environment": {
        "JAVA_HOME": "{env:JAVA_HOME}"
      },
      "extensions": [".java"]
    },
    "laravel-pint": {
      "command": ["npx", "laravel-pint", "--preset", "psr12", "$FILE"],
      "extensions": [".php"]
    },
    "oxfmt": {
      "command": ["npx", "oxfmt", "--write", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc", ".html", ".css", ".scss", ".sass", ".md", ".mdx", ".yaml", ".yml"]
    }
  },
  "instructions": [".opencode/memory/project/user.md", ".opencode/memory/project/tech-stack.md", ".opencode/memory/project/project.md", ".opencode/context/git-context.md"],
  "keybinds": {
    "leader": "ctrl+x",
    "session_parent": "up"
  },
  "mcp": {
    "figma-mcp-go": {
      "command": ["npx", "-y", "@vkhanhqui/figma-mcp-go@latest"],
      "enabled": false,
      "timeout": 120000,
      "type": "local"
    },
    "tilth": {
      "command": ["npx", "-y", "tilth", "--mcp", "--edit"],
      "enabled": true,
      "environment": {
        "TILTH_THREADS": "8"
      },
      "timeout": 120000,
      "type": "local"
    },
    "webclaw": {
      "command": ["webclaw-mcp"],
      "enabled": true,
      "timeout": 120000,
      "type": "local"
    }
  },
  "model": "makora/glm-5.1-fp8",
  "permission": {
    "bash": {
      "*": "allow",
      "cat *": "allow",
      "git branch *": "allow",
      "git checkout *": "ask",
      "git clean *": "ask",
      "git commit *": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git status *": "allow",
      "ls *": "allow",
      "npm *": "allow",
      "npm publish *": "ask",
      "npm run db:push*": "ask",
      "npm run db:reset*": "deny",
      "npx *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny"
    },
    "doom_loop": "ask",
    "edit": "allow",
    "external_directory": "ask",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "*credentials*": "deny",
      "*password*": "deny",
      "*secret*": "deny",
      "*token*": "deny"
    }
  },
  "plugin": ["@tarquinen/opencode-dcp@latest", "@franlol/opencode-md-table-formatter@0.0.3", "openslimedit@latest", "opencodex-fast@latest"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.2": {
          "variants": {
            "fast": {
              "disabled": true
            },
            "high": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.2-codex": {
          "variants": {
            "fast": {
              "disabled": true
            },
            "high": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "xhigh": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.3-codex": {
          "variants": {
            "fast": {
              "disabled": true
            },
            "high": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "xhigh": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.4": {
          "attachment": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "textVerbosity": "medium"
          },
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "variants": {
            "high": {
              "include": ["reasoning.encrypted_content"],
              "reasoningEffort": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto"
            }
          }
        }
      }
    },
    "makora": {
      "name": "Makora",
      "options": {
        "apiKey": "{env:MAKORA_OPTIMIZE_TOKEN}",
        "baseURL": "https://inference.makora.com/v1",
        "timeout": 600000
      },
      "models": {
        "deepseek-v4-flash": {
          "id": "deepseek-ai/DeepSeek-V4-Flash",
          "name": "DeepSeek V4 Flash",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 1048576,
            "output": 1048576
          }
        },
        "deepseek-v4-pro": {
          "id": "deepseek-ai/DeepSeek-V4-Pro",
          "name": "DeepSeek V4 Pro",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 1048576,
            "output": 1048576
          }
        },
        "glm-5.1-fp8": {
          "id": "zai-org/GLM-5.1-FP8",
          "name": "GLM-5.1 FP8",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "gpt-oss-120b": {
          "id": "openai/GPT-OSS-120B",
          "name": "GPT OSS 120B",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "kimi-k2.6-nvfp4": {
          "id": "nvidia/Kimi-K2.6-NVFP4",
          "name": "Kimi K2.6 NVFP4",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "llama-3.3-70b-instruct-fp8": {
          "id": "meta-llama/Llama-3.3-70B-Instruct-FP8",
          "name": "Llama 3.3 70B Instruct FP8",
          "attachment": false,
          "reasoning": false,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "qwen3.6-27b-nvfp4": {
          "id": "unsloth/Qwen3.6-27B-NVFP4",
          "name": "Qwen3.6 27B NVFP4",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen3.6-35b-a3b-nvfp4": {
          "id": "unsloth/Qwen3.6-35B-A3B-NVFP4",
          "name": "Qwen3.6 35B A3B NVFP4",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "share": "manual",
  "small_model": "makora/qwen3.6-27b-nvfp4",
  "watcher": {
    "ignore": ["node_modules/**", ".git/**", "dist/**", "build/**", "*.log", ".DS_Store"]
  },
  "enabled_providers": ["openai", "makora"]
}
