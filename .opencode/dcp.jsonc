{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "toast",
  "commands": {
    "enabled": true,
    "protectedTools": ["observation", "memory-*"],
  },
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true,
  },
  "turnProtection": {
    "enabled": false,
    "turns": 4,
  },
  "protectedFilePatterns": ["**/.env*", "**/AGENTS.md", "**/package.json", "**/tsconfig.json"],
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "maxContextLimit": 100000,
    "modelMaxLimits": {
      // DeepSeek: 1M ctx, 1M out → starts compressing at 800k
      "makora/deepseek-v4-flash": 800000,
      "makora/deepseek-v4-pro": 800000,
      // GPT-5.4: 400k ctx, 128k out
      "openai/gpt-5.4": 250000,
      // GPT-5.x variants: assumed 200k+ ctx windows
      "openai/gpt-5.2": 200000,
      "openai/gpt-5.2-codex": 200000,
      "openai/gpt-5.3-codex": 200000,
      // Kimi / Qwen: 262k ctx, 32k out
      "makora/kimi-k2.6-nvfp4": 200000,
      "makora/qwen3.6-27b-nvfp4": 200000,
      "makora/qwen3.6-35b-a3b-nvfp4": 200000,
    },
    "minContextLimit": 50000,
    "modelMinLimits": {
      "makora/deepseek-v4-flash": 400000,
      "makora/deepseek-v4-pro": 400000,
      "openai/gpt-5.4": 120000,
      "openai/gpt-5.2": 100000,
      "openai/gpt-5.2-codex": 100000,
      "openai/gpt-5.3-codex": 100000,
      "makora/kimi-k2.6-nvfp4": 100000,
      "makora/qwen3.6-27b-nvfp4": 100000,
      "makora/qwen3.6-35b-a3b-nvfp4": 100000,
    },
    "nudgeFrequency": 5,
    "iterationNudgeThreshold": 15,
    "nudgeForce": "soft",
    "protectUserMessages": false,
    "protectedTools": ["observation", "memory-*", "tilth_*"],
  },
  "experimental": {
    "allowSubAgents": false,
    "customPrompts": false,
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": [],
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": [],
    },
  },
}
